{
  "name": "@praktikal/curriculum",
  "version": "0.1.0",
  "description": "Estonian national curriculum and its official implementation materials as open, machine-readable data, plus the deterministic engine that merges, validates, and exports it",
  "license": "MIT",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "merge": "ts-node --transpile-only src/merge.ts",
    "validate": "ts-node --transpile-only src/validate.ts",
    "manifest": "ts-node --transpile-only src/manifest.ts",
    "outcomes": "ts-node --transpile-only src/outcomes.ts",
    "jsonld": "ts-node --transpile-only src/jsonld.ts",
    "check:schema": "ts-node --transpile-only src/checkSchema.ts",
    "check:identities": "ts-node --transpile-only src/merge.ts --frozen-identities",
    "reconcile": "ts-node --transpile-only src/reconcile.ts",
    "test": "ts-node --transpile-only src/reconcile.spec.ts && ts-node --transpile-only src/jsonld.spec.ts",
    "build:data": "pnpm merge && pnpm manifest && pnpm outcomes && pnpm jsonld",
    "check": "pnpm check:schema && pnpm validate"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  }
}
