      "kind": "topic",
      "title": "Keskaegse Euroopa naabrid: araablased, Bütsants, viikingid, Vana-Vene riik",
      "children": []
    },
    { "kind": "topic", "title": "Ristisõjad", "children": [] },
    {
      "kind": "topic",
      "title": "Haridus, ülikoolid ja teadus",
      "children": []
    },
    { "kind": "topic", "title": "Eesti keskajal", "children": [] },
    {
      "kind": "section",
      "title": "Maailm varauusajal 1492–1600",
      "children": []
    },
    {
      "kind": "topic",
      "title": "Maadeavastused",
      "children": [
        {
          "kind": "outcome",
          "text": "Selgitab Christoph Kolumbuse rolli Ameerika avastajana eurooplaste jaoks;",
          "outcomeType": "knowledge"
        },
        {
          "kind": "outcome",
          "text": "toob näiteid hispaanlastest ja portugallastest kolonisaatorite eesmärkidest ja tegevusest Ameerikas.",
          "outcomeType": "knowledge"
        },
        {
          "kind": "outcome",
          "text": "Märgib kaardile maadeavastajate retked. Kirjeldab retkesid oma sõnadega kasutades geograafia termineid.",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "Selgitab eurooplaste kolonialismi põhjuseid ja tagajärgi Uues Maailmas;",
          "outcomeType": "knowledge"
        },
        {
          "kind": "outcome",
          "text": "toob näiteid hispaanlaste ja portugallaste tegevusest Uue Maailma avastus- ja vallutusretkedel;",
          "outcomeType": "knowledge"
        },
        {
          "kind": "outcome",
          "text": "annab hinnangu eurooplaste kolonisatsioonile Uues Maailmas kolonistide, põliselanike ja tänapäeva seisukohast.",
          "outcomeType": "attitude"
        }
      ]
    },
    {
      "kind": "topic",
      "title": "Reformatsioon ja vastureformatsoon",
      "children": [
        {
          "kind": "outcome",
          "text": "Toob näiteid reformatsiooni eesmärkidest, levikust ja mõjust;",
          "outcomeType": "knowledge"
        },
        {
          "kind": "outcome",
          "text": "nimetab vastureformatsiooni põhjuseid ja tagajärgi.",
          "outcomeType": "knowledge"
        },
        {
          "kind": "outcome",
          "text": "uurib ja tutvustab mõne keskajal elanud inimese võimalusi ja valikuid Marthin Lutheri ja tema mõttekaaslaste näitel",
          "outcomeType": "skill"
        }
      ]
    },
    {
      "kind": "topic",
      "title": "Renessanss ja humanism",
      "children": [
        {
          "kind": "outcome",
          "text": "võrdleb skolastikat ja humanismi;",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "toob näiteid humanistide, maadeavastajate ja renessansiajastu õpetlaste tegevusest ja selgitab nende tegevuse mõju teadusliku maailmapildi kujunemisele.",
          "outcomeType": "knowledge"
        },
        {
          "kind": "outcome",
          "text": "selgitab, kuidas teadusliku maailmapildi kujunemine hiliskeskajal on mõjutanud inimeste suhtumist loodusesse.",
          "outcomeType": "knowledge"
        }
      ]
    },
