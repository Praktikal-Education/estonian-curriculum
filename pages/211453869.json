{
  "content": [
    {
      "kind": "section",
      "title": "Ajaloo õpitulemused ja õppesisu III kooliastmes",
      "children": [
        { "kind": "text", "html": "<p>Keskaeg ja varauusaeg</p>" },
        {
          "kind": "section",
          "title": "Maailm keskajal 476–1492",
          "children": [
            {
              "kind": "section",
              "title": "Keskaja mõiste, üldiseloomustus ja perioodiseerimine",
              "children": [
                {
                  "kind": "text",
                  "html": "<p>Teema kaudu kujundatakse õpilasel oskust orienteeruda ajas, analüüsida ja mõista seoseid ning mõtestada ajaloolise keskkonna kujunemist.</p>"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "kind": "topic",
      "title": "Seisused, läänikord ja eluolu",
      "children": [
        {
          "kind": "outcome",
          "text": "iseloomustab seisuslikku ühiskonda: nimetab seisused ja ülesanded, selgitab jumala tähtsust keskaja inimese maailmapildis;",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "iseloomustab läänikorda",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "kasutab kontekstis mõistet senjöör ja vasall ja truudus, feodaal",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "kirjeldab feodaalset hierarhiat, selgitab seoseid.",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "iseloomustab läänimeeste elulaadi;",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "kirjeldab keskaegset linnust,",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "analüüsib linnuselu vooruseid ja puuduseid keskaja inimese seisukohast",
          "outcomeType": "skill"
        }
      ]
    },
    {
      "kind": "topic",
      "title": "Ristiusk, kirik ja kultuur",
      "children": [
        {
          "kind": "outcome",
          "text": "iseloomustab kiriku rolli keskaja ühiskonna ja üksikisiku elus;",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "kirjeldab kiriku struktuuri,",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "Selgitab mõne näite põhjal, mil moel võivad ehitised, kunstiteosed ja muud esemed anda teavet keskaegse inimese maailmapildi kohta.",
          "outcomeType": "knowledge"
        },
        {
          "kind": "outcome",
          "text": "teeb kirjalike tekstide või kunstiteoste põhjal lihtsamaid järeldusi, hinnates autori taotlusi ja veendumusi ajaloolises kontekstis.",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "tunneb ära ja nimetab romaani ja gooti stiili arhitektuuris (ümarkaar/ teravkaar, hoone üldilme, akende suurus ja hulk,detailid);",
          "outcomeType": "knowledge"
        },
        {
          "kind": "outcome",
          "text": "iseloomustab kunstiteoste toel keskaja kujutavat kunsti (temaatika, kujutamisviis, kunstniku staatus, eesmärgid).",
          "outcomeType": "skill"
        }
      ]
    },
    { "kind": "topic", "title": "Euroopa riigid varakeskajal", "children": [] },
    { "kind": "topic", "title": "Linnad ja linnaelu", "children": [] },
    { "kind": "topic", "title": "Euroopa riigid kõrgkeskajal", "children": [] },
