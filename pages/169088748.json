            },
            {
              "kind": "outcome",
              "text": "järgib õppekäikudel liikudes suunatult ohutusreegleid;",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "tunneb õpitud liiklusreegleid ja märke;",
              "outcomeType": "knowledge"
            },
            {
              "kind": "outcome",
              "text": "hoidub nähtavatest ohtudest, kutsub vajaduse korral abi;",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "teab ühissõiduki kasutamise reegleid;",
              "outcomeType": "knowledge"
            },
            {
              "kind": "outcome",
              "text": "oskab käituda ohuolukorras, teab hädaabinumbreid;",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "oskab paluda ja kutsuda abi.",
              "outcomeType": "skill"
            }
          ]
        },
        {
          "kind": "section",
          "title": "III arengutaseme lõpuks",
          "children": [
            {
              "kind": "outcome",
              "text": "liikleb võimalikult iseseisvalt koduasulas;",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "oskab õppekäikudel liigelda vastavalt liiklusreeglitele ja -märkidele;",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "loeb ja mõistab hoiatus- ja teabemärke;",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "märkab endale ja teistele ohtlikke olukordi ja reageerib neile, kutsub abi;",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "keeldub teda kahjustavatest tegevustest.",
              "outcomeType": "skill"
            }
          ]
        },
        {
          "kind": "section",
          "title": "Soovituslik õppesisu",
          "children": [
            { "kind": "text", "html": "<p>Liiklus. Ohutusnõuete täitmine.</p>" }
          ]
        }
      ]
    },
