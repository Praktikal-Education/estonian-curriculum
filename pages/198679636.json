        {
          "kind": "outcome",
          "text": "käitub keskkonnahoidliku tarbijana;",
          "outcomeType": "attitude"
        },
        {
          "kind": "outcome",
          "text": "leiab võimalusi materjale/riideid isikupäraselt taaskasutada;",
