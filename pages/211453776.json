    {
      "kind": "topic",
      "title": "Valguse murdumine",
      "children": [
        {
          "kind": "outcome",
          "text": "rakendab valguse murdumise seaduspärasust läätse tööpõhimõtte selgitamiseks ja probleemülesandeid lahendades",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "seletab fookuse, fookuskauguse ja optilise tugevuse mõistet",
          "outcomeType": "knowledge"
        },
        {
          "kind": "outcome",
          "text": "tunneb erinevate läätsede omadusi ja seostab kujutiste tekkimist läätsede omadustega",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "konstrueerib kiirte käiku kumer- ja nõgusläätses, eristab tõelist ja näivat kujutist",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "selgitab jooniste järgi erinevate optiliste seadmete tööpõhimõtet",
          "outcomeType": "knowledge"
        },
        {
          "kind": "outcome",
          "text": "selgitab silma kui optilise süsteemi tööpõhimõtet ning lühi- ja kaugnägemise põhjuseid",
          "outcomeType": "knowledge"
        },
        {
          "kind": "outcome",
          "text": "rakendab probleemülesandeid lahendades seost: $D=\\frac{1}{f}$",
          "outcomeType": "skill"
        },
        {
          "kind": "section",
          "title": "Õppesisu",
          "children": [
            {
              "kind": "text",
              "html": "<p>Valguse murdumine üleminekul ühest optilsest keskkonnast teise. Täielik peegeldumine. Liitvalguse lahutamine spektriks. Kumer- ja nõguslääts. Tõeline ja näiline kujutis. Silm ja nägemine. Lühi- ja kaugnägelikkus, prillid.</p>"
            }
          ]
        },
