    {
      "kind": "topic",
      "title": "Jõud looduses",
      "children": [
        {
          "kind": "outcome",
          "text": "võrdleb eri kehadele mõjuvat raskusjõudu ja seostab seda keha massiga",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "uurib hõõrdejõudu ja seletab selle mõju kehade liikumisele, analüüsib graafiliselt hõõrdejõu sõltuvust rõhumisjõust",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "uurib elastsusjõudu ja seletab selle tekkimise põhjuseid",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "oskab kasutada dünamomeetrit erinevate jõudude mõõtmiseks",
          "outcomeType": "skill"
        },
        {
          "kind": "outcome",
          "text": "rakendab probleemülesandeid lahendades seost: $F=mg$",
          "outcomeType": "skill"
        },
        {
          "kind": "section",
          "title": "Õppesisu",
          "children": [
            {
              "kind": "text",
              "html": "<p>Gravitatsioon. Raskusjõud. Hõõrdumine, hõõrdejõud. Kehade elastsus ja plastsus. Deformeerimine, elastsusjõud. Dünamomeetri tööpõhimõte. Kehale mõjuvate jõudude tasakaal.</p>"
            }
          ]
        },
