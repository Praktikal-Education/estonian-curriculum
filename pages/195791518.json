          "title": "Õpipädevus",
          "children": [
            {
              "kind": "outcome",
              "text": "Õpilane õpib vastavalt oma võimetele",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "täidab korrektselt jõukohaseid ülesandeid individuaalselt õpetaja suunamisel.",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "Planeerib suunamisel õppimist, sh enesekontrolli.",
              "outcomeType": "skill"
            }
          ]
        },
        {
          "kind": "section",
          "title": "Suhtluspädevus",
          "children": [
            {
              "kind": "outcome",
              "text": "Õpilane suhtleb suhtlemispartnereid arvestades, esitab arusaadavalt ja viisakalt oma vajadusi ja soove, kasutades selleks erinevaid teabevahendeid.",
              "outcomeType": "skill"
            }
          ]
        },
        {
          "kind": "section",
          "title": "Matemaatika-, loodusteaduste- ja tehnoloogiaalane pädevus",
          "children": [
            {
              "kind": "outcome",
              "text": "Õpilane lahendab suunamisel eakohaseid probleemsituatsioone, kasutades omandatud matemaatilisi, loodusteaduslikke ja tehnoloogiaalaseid teadmisi-oskusi ja abivahendeid",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "tegutseb võimete piires loodust ja keskkonda säästvalt.",
              "outcomeType": "attitude"
            }
          ]
        },
        {
          "kind": "section",
          "title": "Digipädevus",
          "children": [
            {
              "kind": "outcome",
              "text": "Õpilane leiab juhendamisel teavet veebist, tunneb levinumaid otsingumootoreid (nt Google) ja kasutab arvuti jm digivahendite abi õppetöös.",
              "outcomeType": "skill"
            }
          ]
        }
      ]
    },
    {
      "kind": "section",
      "title": "8.-9. klassi õpilastel kujundatavad üldpädevused:",
      "children": [
        {
          "kind": "section",
          "title": "Kultuuri- ja väärtuspädevus",
          "children": [
            {
              "kind": "outcome",
              "text": "Õpilane tunnetab end oma rahvuse liikmena ja Eesti kodanikuna, väärtustab maailma eri rahvaste ja kultuuride mitmekesisust, suhtub teistest rahvustest inimestesse eelarvamuste vabalt ja lugupidavalt, tunneb ja austab oma keelt ja kultuuri",
              "outcomeType": "attitude"
            },
            {
              "kind": "outcome",
              "text": "väärtustab eesti keele ja kultuuri säilimist ja arengut",
              "outcomeType": "attitude"
            },
            {
              "kind": "outcome",
              "text": "tunneb ja järgib üldtunnustatud väärtusi ja kõlbluspõhimõtteid, ei jää ükskõikseks, kui neid eiratakse, ning sekkub vajaduse korral oma võimaluste piires.",
              "outcomeType": "attitude"
            }
          ]
        },
        {
          "kind": "section",
          "title": "Sotsiaalne ja kodanikupädevus",
          "children": [
            {
              "kind": "outcome",
              "text": "Õpilane on aktiivne ja vastutustundlik kodanik, kes on huvitatud oma kooli, kodukoha ja riigi arengust",
              "outcomeType": "attitude"
            },
            {
              "kind": "outcome",
              "text": "teab oma peamisi õigusi ja kohustusi, oskab nende eest seista, arvestab rühma huvisid ja isiklikku huvi",
              "outcomeType": "knowledge"
            },
            {
              "kind": "outcome",
              "text": "järgib vastutustundlikult ühiselu reegleid, konflikte lahendades arvestab seadusi ning moraalinorme.",
              "outcomeType": "attitude"
            }
          ]
        },
        {
          "kind": "section",
          "title": "Enesemääratluspädevus",
          "children": [
            {
              "kind": "outcome",
              "text": "Õpilane mõistab ja väärtustab iseennast ja enda arengut, hindab adekvaatselt oma võimeid ja toimetulekut igapäevaelus, juhib oma käitumist erinevates olukordades",
              "outcomeType": "knowledge"
            },
            {
              "kind": "outcome",
              "text": "väärtustab tervislikku eluviisi, on füüsiliselt aktiivne.",
              "outcomeType": "attitude"
            }
          ]
        },
        {
          "kind": "section",
          "title": "Õpipädevus",
          "children": [
            {
              "kind": "outcome",
              "text": "Õpilane õpib vastavalt oma võimetele, planeerib õppimist, sh enesekontrolli, järgib kavandatut.",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "Täidab korrektselt jõukohaseid ülesandeid individuaalselt ja rühmas, kasutab sobivaid teabevahendeid.",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "On avatud uutele teadmistele ja oskustele.",
              "outcomeType": "attitude"
            }
          ]
        },
        {
          "kind": "section",
          "title": "Suhtluspädevus",
          "children": [
            {
              "kind": "outcome",
              "text": "Õpilane suhtleb olukorda ja suhtlemispartnereid arvestades, esitab oma soove, selgitab oma seisukohti, osaleb arutelus",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "loeb, mõistab, kirjutab ja loob tekste iseseisvaks toimetulekuks vajalikul tasemel, kasutab teabevahendeid.",
              "outcomeType": "skill"
            }
          ]
        },
        {
          "kind": "section",
          "title": "Matemaatika-, loodusteaduste- ja tehnoloogiaalane pädevus",
          "children": [
            {
              "kind": "outcome",
              "text": "Õpilane lahendab elulisi probleemsituatsioone, kasutades omandatud matemaatilisi, loodusteaduslikke ja/või tehnoloogiaalaseid teadmisi-oskusi ning (abi)vahendeid",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "mõistab inimese ja keskkonna vahelisi seoseid, suhtub elukeskkonda vastutustundlikult ja hoolivalt, elab ning tegutseb loodust ja keskkonda säästvalt.",
              "outcomeType": "knowledge"
            }
          ]
        },
        {
          "kind": "section",
          "title": "Ettevõtlikkuspädevus",
          "children": [
            {
              "kind": "outcome",
              "text": "Õpilane on tegutsemisaldis, väärtustab praktilist tööd ja on valmis kutse- ja elukestvaks õppeks.",
              "outcomeType": "attitude"
            },
            {
              "kind": "outcome",
              "text": "Hindab adekvaatselt oma võimeid.",
              "outcomeType": "knowledge"
            },
            {
              "kind": "outcome",
              "text": "Püstitab ja täidab endale seatud eesmärke ning võtab vastutuse oma tegude eest.",
              "outcomeType": "skill"
            }
          ]
        },
        {
          "kind": "section",
          "title": "Digipädevus",
          "children": [
            {
              "kind": "outcome",
              "text": "Õpilane orienteerub ja tegutseb infotehnoloogilises maailmas eesmärgipäraselt ja turvaliselt.",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "Otsib ja kasutab infot, tunneb lihtsamaid programme ja keskkondi.",
              "outcomeType": "skill"
            },
            {
              "kind": "outcome",
              "text": "Järgib digikeskkonnas üldkehtivaid moraali- ja väärtuspõhimõtteid.",
              "outcomeType": "attitude"
            }
          ]
        }
      ]
    }
  ]
}
