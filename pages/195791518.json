            {
              "kind": "outcome",
              "text": "teab oma peamisi õigusi ja kohustusi ning järgib kooli- ja klassireegleid.",
              "outcomeType": "knowledge"
            }
          ]
        },
        {
          "kind": "section",
          "title": "Enesemääratluspädevus",
          "children": [
            {
              "kind": "outcome",
              "text": "Õpilane hindab suunamisel oma võimeid ja toimetulekut igapäevaelus",
